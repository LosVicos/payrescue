# --- Your customer's Stripe account (the SaaS founder using PayRescue) ---
# In production this comes per-tenant via Stripe Connect. For the MVP you test
# against ONE Stripe account using its secret key + webhook signing secret.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email sending (dunning sequence). Get a free key at resend.com ---
RESEND_API_KEY=re_xxx
FROM_EMAIL=billing@yourdomain.com
FROM_NAME=Acme Billing

# --- Optional: Slack incoming webhook for instant "payment failed" alerts ---
SLACK_WEBHOOK_URL=

# --- App config ---
PORT=3000
# Public base URL of THIS app (used to build the customer recovery link page)
APP_BASE_URL=http://localhost:3000
